{
  "name": "Reset Challenge — Checkout Session Creator",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "reset-challenge-checkout",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567891",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "reset-challenge-checkout"
    },
    {
      "parameters": {
        "method": "POST",
